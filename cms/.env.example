# Strapi-Backend lokale Config (cms/.env wird per .gitignore ignoriert)
# Generiere Secrets z.B. mit: openssl rand -base64 32

HOST=0.0.0.0
PORT=1337
APP_KEYS=key1,key2
API_TOKEN_SALT=tobereplaced
ADMIN_JWT_SECRET=tobereplaced
TRANSFER_TOKEN_SALT=tobereplaced
JWT_SECRET=tobereplaced
ENCRYPTION_KEY=tobereplaced

# Datenbank (Default: SQLite lokal)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db
