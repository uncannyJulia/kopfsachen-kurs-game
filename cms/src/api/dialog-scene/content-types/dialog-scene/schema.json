{
  "kind": "collectionType",
  "collectionName": "dialog_scenes",
  "info": {
    "singularName": "dialog-scene",
    "pluralName": "dialog-scenes",
    "displayName": "Dialog Scene",
    "description": "Eine Szene mit Hintergrund, Charakter und Dialog-Nodes"
  },
  "options": { "draftAndPublish": true },
  "attributes": {
    "chapter": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::chapter.chapter",
      "inversedBy": "dialogScenes"
    },
    "sceneOrder": {
      "type": "integer",
      "required": true,
      "default": 1,
      "min": 1
    },
    "phase": {
      "type": "enumeration",
      "enum": ["ankommen", "erleben", "informieren", "ueben", "alltag"],
      "required": true,
      "default": "ankommen",
      "description": "Welche der 5 Kapitel-Phasen diese Szene gehoert"
    },
    "title": {
      "type": "string",
      "description": "Interner Szenen-Titel fuers Admin, z.B. Intro mit Evu"
    },
    "background": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "description": "Optional. Wenn leer: schlichter Hintergrund."
    },
    "character": {
      "type": "enumeration",
      "enum": ["evu", "toni", "neo", "manu", "psycholog", "niemand"],
      "default": "evu",
      "required": true
    },
    "startNodeId": {
      "type": "integer",
      "required": true,
      "default": 1
    },
    "nodes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::dialog-node.dialog-node",
      "mappedBy": "scene"
    }
  }
}
